#!/usr/bin/env bash

if [ -z "$1" ]; then
  echo  "Please provide a valid argument: log-archive [directory]"
  exit 1
fi

dir="$1"

time=$(date +%Y%m%d_%H%M%S)
filename="logs_archive_${time}.tar.gz"

echo "Compressing directory  $dir"

stderr=$(tar --ignore-failed-read -czf "$filename" "$dir" 2>&1 >/dev/null)

if [ -n "$stderr" ]; then
  echo "Warning: some files were skipped due to permission denied"
  fi

echo "Archive created: $filename"
echo "Done"
